# ── Supabase (Vite frontend) ──
# Copia este archivo a .env.local y rellena con tus valores reales.
# SOLO estas dos claves van al frontend (el bundle de Vite es público).
# NUNCA pongas service_role, secret, jwt_secret ni POSTGRES_* en el frontend.

VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu-anon-o-publishable-key"

# ── Web Push (opcional) ── clave PÚBLICA VAPID (se puede exponer)
# Genérala con:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=""
